theorem fn.eq_on_dom.eq [f g : term] : (f : Fn) (g : Fn) (dom(f) = dom(g))
    (έΙΑx έΙΙ dom(f), f(x) = g(x))
    |- f = g
proof
    -- chain f = {έθρx, f(x)έθσ | x έΙΙ dom(f)} by fn.pairs;
    --         = {έθρx, g(x)έθσ | x έΙΙ dom(f)} given έΙΑx έΙΙ dom(f), f(x) = g(x);
    --         = {έθρx, g(x)έθσ | x έΙΙ dom(g)} given dom(f) = dom(g);
    --         = g                        by fn.pairs;
    chain f = {έθρx, f(x)έθσ | x έΙΙ dom(f)} as todo;
            = {έθρx, g(x)έθσ | x έΙΙ dom(f)} as todo;
            = {έθρx, g(x)έθσ | x έΙΙ dom(g)} as todo;
            = g                        as todo;
qed

notation fn_restriction
    term ::= term " έΗ╛ " term
end

definition
    f έΗ╛ A := {x έΙΙ f | ╧ΑέΓΒ(x) έΙΙ A}
end

theorem fn.restriction.is [f X : term] : (f : Fn)
    |- f έΗ╛ X : Fn
proof
    todo
qed

theorem fn.restriction.pairs [f X : term] : (f : Fn)
    |- f έΗ╛ X = {έθρx, f(x)έθσ | x έΙΙ dom(f) έΙσ X}
proof
    todo
qed

theorem fn.restriction.eq [f g X : term] : (f : Fn) (g : Fn) (dom(f) έΙσ X = dom(g) έΙσ X)
    (έΙΑx έΙΙ dom(f) έΙσ X, f(x) = g(x))
    |- f έΗ╛ X = g έΗ╛ X
proof
    -- chain f έΗ╛ X 
    --     = {έθρx, f(x)έθσ | x έΙΙ dom(f) έΙσ X} by fn.restriction.pairs;
    --     = {έθρx, g(x)έθσ | x έΙΙ dom(f) έΙσ X} given έΙΑx έΙΙ X, f(x) = g(x);
    --     = {έθρx, g(x)έθσ | x έΙΙ dom(g) έΙσ X} given dom(f) έΙσ X = dom(g) έΙσ X;
    --     = g έΗ╛ X                        by fn.restriction.pairs;
    chain f έΗ╛ X 
        = {έθρx, f(x)έθσ | x έΙΙ dom(f) έΙσ X} as todo;
        = {έθρx, g(x)έθσ | x έΙΙ dom(f) έΙσ X} as todo;
        = {έθρx, g(x)έθσ | x έΙΙ dom(g) έΙσ X} as todo;
        = g έΗ╛ X                        as todo;
qed

## Function properties & Composition

The image of a function under a set is the set resulting from applying the function to every element of the set

notation image_set
    term (1000) ::= term "[" term "]"
end

definition
    f:term [A] := {f(a) | a έΙΙ A}
end

theorem image.def [f A : term] :
    |- έΙΑy, y έΙΙ f[A] έΗΦ έΙΔa έΙΙ A, y = f(a)
proof
    suffices έΙΑy, y έΙΙ {f(a) | a έΙΙ A} έΗΦ έΙΔa έΙΙ A, y = f(a);
    thus έΙΑy, y έΙΙ {f(a) | a έΙΙ A} έΗΦ (έΙΔa, a έΙΙ A έΙπ y = f(a)) by set_map.def [f(_)] [A];
    done logically
qed

Importantly, every image has a preimage, which we'll have as the set of terms which are mapped to a specific set under a function

notation preimage_set
    term (1000) ::= term "έΒ╗┬╣" "[" term "]"
end

definition
    f:termέΒ╗┬╣[A] := {x έΙΙ dom(f) | f(x) έΙΙ A}
end

theorem preimage.def [f A : term] :
    |- έΙΑx, x έΙΙ fέΒ╗┬╣[A] έΗΦ (x έΙΙ dom(f) έΙπ f(x) έΙΙ A)
proof
    suffices έΙΑx, x έΙΙ {x έΙΙ dom(f) | f(x) έΙΙ A} έΗΦ (x έΙΙ dom(f) έΙπ f(x) έΙΙ A);
    done by zfc.extensionality
qed

A surjection, also known as an onto function, between sets is a mapping where the range is the same as the codomain

notation surjection
    term ::= term " έΗι " term
end

definition
    A έΗι B := {f έΙΙ (A έΗΤ B) | ran(f) = B}
end

theorem surj_on.def [A B : term] :
    |- έΙΑf, f έΙΙ (A έΗι B) έΗΦ (f έΙΙ (A έΗΤ B) έΙπ ran(f) = B)
proof
    suffices έΙΑf, f έΙΙ {f έΙΙ (A έΗΤ B) | ran(f) = B} έΗΦ (f έΙΙ (A έΗΤ B) έΙπ ran(f) = B);
    done by zfc.extensionality
qed

An injection, a one-to-one function, between sets is one where every element of the domain is mapped to a unique element in the range

notation injection
    term ::= term " έΗμ " term
end

definition
    A έΗμ B := {f έΙΙ (A έΗΤ B) | έΙΑx, έΙΑy, x έΙΙ A έΙπ y έΙΙ A έΙπ f(x) = f(y) έΗΤ x = y}
end

theorem inj_on.def [A B : term] :
    |- έΙΑf, f έΙΙ (A έΗμ B) έΗΦ (f έΙΙ (A έΗΤ B) έΙπ (έΙΑx, έΙΑy, x έΙΙ A έΙπ y έΙΙ A έΙπ f(x) = f(y) έΗΤ x = y))
proof
    suffices έΙΑf, f έΙΙ {f έΙΙ (A έΗΤ B) | έΙΑx, έΙΑy, x έΙΙ A έΙπ y έΙΙ A έΙπ f(x) = f(y) έΗΤ x = y} έΗΦ (f έΙΙ (A έΗΤ B) έΙπ (έΙΑx, έΙΑy, x έΙΙ A έΙπ y έΙΙ A έΙπ f(x) = f(y) έΗΤ x = y));
    done by zfc.extensionality
qed

definition
    f : Inj := f έΙΙ (dom(f) έΗμ ran(f))
end

theorem inj.def [f : term] :
    |- f : Inj έΗΦ f έΙΙ (dom(f) έΗμ ran(f))
proof
    done by iff.refl [f : Inj]
qed

A bijection between sets is a function that is both injective and surjective

notation bijection
    term ::= term " έΗΦ " term
end

definition
    A έΗΦ B := {f έΙΙ (A έΗμ B) | ran(f) = B}
end

theorem bij_on.def [A B : term] :
    |- έΙΑf, f έΙΙ (A έΗΦ B) έΗΦ (f έΙΙ (A έΗμ B) έΙπ ran(f) = B)
proof
    suffices έΙΑf, f έΙΙ {f έΙΙ (A έΗμ B) | ran(f) = B} έΗΦ (f έΙΙ (A έΗμ B) έΙπ ran(f) = B);
    done by zfc.extensionality
qed

definition
    f : Bij := f έΙΙ (dom(f) έΗΦ ran(f))
end

theorem bij.def [f : term] :
    |- f : Bij έΗΦ f έΙΙ (dom(f) έΗΦ ran(f))
proof
    done by iff.refl [f : Bij]
qed

This theorem follows cleanly from the definitions for injective, bijective, and surjective functions

theorem bij_on.is_inj_and_surj [f A B : term] :
    |- f έΙΙ (A έΗΦ B) έΗΦ (f έΙΙ (A έΗμ B) έΙπ f έΙΙ (A έΗι B))
proof
    follows f έΙΙ (A έΗΦ B) έΗΦ (f έΙΙ (A έΗμ B) έΙπ ran(f) = B) by bij_on.def;
    follows f έΙΙ (A έΗι B) έΗΦ (f έΙΙ (A έΗΤ B) έΙπ ran(f) = B) by surj_on.def;
    follows f έΙΙ (A έΗμ B) έΗΤ f έΙΙ (A έΗΤ B) by inj_on.def;
    done logically
qed

We can define an inverse relation simply as the swapped coordinates of the relation

notation inverse_relation
    term (1000) ::= term "έΒ╗┬╣"
end

definition
    f:termέΒ╗┬╣ := {έθρ╧ΑέΓΓ(p), ╧ΑέΓΒ(p)έθσ | p έΙΙ f}
end

Swapping the components of every pair in f swaps the roles of the domain and the range.

lemma inv.dom [f : term] :
    |- dom(fέΒ╗┬╣) = ran(f)
proof
    follows έΙΑx, x έΙΙ dom(fέΒ╗┬╣) έΗΦ έΙΔy έΙΙ fέΒ╗┬╣, x = ╧ΑέΓΒ(y) by dom.def;
    thus έΙΑy, y έΙΙ fέΒ╗┬╣ έΗΦ έΙΔp έΙΙ f, y = έθρ╧ΑέΓΓ(p), ╧ΑέΓΒ(p)έθσ by set_map.def [έθρ╧ΑέΓΓ(_), ╧ΑέΓΒ(_)έθσ] [f];
    follows έΙΑp, ╧ΑέΓΒ(έθρ╧ΑέΓΓ(p), ╧ΑέΓΒ(p)έθσ) = ╧ΑέΓΓ(p) by opair_first.def;
    follows έΙΑx, x έΙΙ ran(f) έΗΦ έΙΔp έΙΙ f, x = ╧ΑέΓΓ(p) by ran.def;
    hence έΙΑx, x έΙΙ dom(fέΒ╗┬╣) έΗΦ x έΙΙ ran(f) logically;
    done by zfc.extensionality
qed

lemma inv.ran [f : term] :
    |- ran(fέΒ╗┬╣) = dom(f)
proof
    follows έΙΑx, x έΙΙ ran(fέΒ╗┬╣) έΗΦ έΙΔy έΙΙ fέΒ╗┬╣, x = ╧ΑέΓΓ(y) by ran.def;
    thus έΙΑy, y έΙΙ fέΒ╗┬╣ έΗΦ έΙΔp έΙΙ f, y = έθρ╧ΑέΓΓ(p), ╧ΑέΓΒ(p)έθσ by set_map.def [έθρ╧ΑέΓΓ(_), ╧ΑέΓΒ(_)έθσ] [f];
    follows έΙΑp, ╧ΑέΓΓ(έθρ╧ΑέΓΓ(p), ╧ΑέΓΒ(p)έθσ) = ╧ΑέΓΒ(p) by opair_second.def;
    follows έΙΑx, x έΙΙ dom(f) έΗΦ έΙΔp έΙΙ f, x = ╧ΑέΓΒ(p) by dom.def;
    hence έΙΑx, x έΙΙ ran(fέΒ╗┬╣) έΗΦ x έΙΙ dom(f) logically;
    done by zfc.extensionality
qed

The following proof gives us a way to reason with and construct what fέΒ╗┬╣ looks like

lemma inv.mem [f A B : term] : (f έΙΙ Rel(A, B))
    |- έΙΑa, έΙΑb, έθρa, bέθσ έΙΙ fέΒ╗┬╣ έΗΦ έθρb, aέθσ έΙΙ f
proof
    arbitrary a; arbitrary b;
    follows f έΛΗ A ├Ω B by rel_on.def;
    thus έΙΑy, y έΙΙ fέΒ╗┬╣ έΗΦ έΙΔp έΙΙ f, y = έθρ╧ΑέΓΓ(p), ╧ΑέΓΒ(p)έθσ by set_map.def [έθρ╧ΑέΓΓ(_), ╧ΑέΓΒ(_)έθσ] [f];
    assume έθρb, aέθσ έΙΙ f then έθρa, bέθσ έΙΙ fέΒ╗┬╣ as
        follows ╧ΑέΓΒ(έθρb, aέθσ) = b by opair_first.def;
        follows ╧ΑέΓΓ(έθρb, aέθσ) = a by opair_second.def;
        hence έθρa, bέθσ = έθρ╧ΑέΓΓ(έθρb, aέθσ), ╧ΑέΓΒ(έθρb, aέθσ)έθσ logically;
        done logically
        ;
    assume έθρa, bέθσ έΙΙ fέΒ╗┬╣ then έθρb, aέθσ έΙΙ f as
        obtain p st p έΙΙ f έΙπ έθρa, bέθσ = έθρ╧ΑέΓΓ(p), ╧ΑέΓΒ(p)έθσ logically;
        follows p έΙΙ A ├Ω B by sub.def given f έΛΗ A ├Ω B;
        obtain c st c έΙΙ A and d st d έΙΙ B έΙπ p = έθρc, dέθσ by cart_prod.def;
        follows ╧ΑέΓΒ(p) = c by opair_first.def given p = έθρc, dέθσ;
        follows ╧ΑέΓΓ(p) = d by opair_second.def given p = έθρc, dέθσ;
        follows a = d έΙπ b = c by opair.eq given έθρa, bέθσ = έθρ╧ΑέΓΓ(p), ╧ΑέΓΒ(p)έθσ;
        done logically
        ;
    done logically
qed

The inverse of a relation between A and B is itself a relation, between B and A.

lemma inv.rel [f A B : term] : (f έΙΙ Rel(A, B))
    |- fέΒ╗┬╣ έΙΙ Rel(B, A)
proof
    -- A relation is just some subset of the cartesian product
    follows f έΛΗ A ├Ω B by rel_on.def;
    follows έΙΑa, έΙΑb, έθρa, bέθσ έΙΙ fέΒ╗┬╣ έΗΦ έθρb, aέθσ έΙΙ f by inv.mem;
    suffices έΙΑy, y έΙΙ fέΒ╗┬╣ έΗΤ y έΙΙ B ├Ω A by rel_on.def, sub.def;
    arbitrary y;
    assume y έΙΙ fέΒ╗┬╣ then y έΙΙ B ├Ω A as
        -- every element of fέΒ╗┬╣ is a swapped pair from f
        thus έΙΑz, z έΙΙ fέΒ╗┬╣ έΗΦ έΙΔp έΙΙ f, z = έθρ╧ΑέΓΓ(p), ╧ΑέΓΒ(p)έθσ by set_map.def [έθρ╧ΑέΓΓ(_), ╧ΑέΓΒ(_)έθσ] [f];
        obtain p st p έΙΙ f έΙπ y = έθρ╧ΑέΓΓ(p), ╧ΑέΓΒ(p)έθσ logically;
        -- inv.mem swaps the pair back into f
        follows έθρ╧ΑέΓΒ(p), ╧ΑέΓΓ(p)έθσ έΙΙ f logically;
        follows έθρ╧ΑέΓΒ(p), ╧ΑέΓΓ(p)έθσ έΙΙ A ├Ω B by sub.def given f έΛΗ A ├Ω B;
        hence ╧ΑέΓΒ(p) έΙΙ A έΙπ ╧ΑέΓΓ(p) έΙΙ B by cart_prod.def, opair.eq;
        done by cart_prod.def
        ;
    done logically
qed

notation function_composition
    term (400) ::= term " έΙα " term
end

definition
    g έΙα f := {έθρx, g(f(x))έθσ | x έΙΙ {x έΙΙ dom(f) | f(x) έΙΙ dom(g)}}
end

theorem composition.def [f g : term] :
    |- έΙΑy, y έΙΙ (g έΙα f) έΗΦ έΙΔx, (x έΙΙ dom(f) έΙπ f(x) έΙΙ dom(g)) έΙπ y = έθρx, g(f(x))έθσ
proof
    follows έΙΑy, y έΙΙ (g έΙα f) έΗΦ έΙΔx έΙΙ {x έΙΙ dom(f) | f(x) έΙΙ dom(g)}, y = έθρx, g(f(x))έθσ
        by set_map.def [έθρ_, g(f(_))έθσ] [{x έΙΙ dom(f) | f(x) έΙΙ dom(g)}];
    hence έΙΑx, x έΙΙ {x έΙΙ dom(f) | f(x) έΙΙ dom(g)} έΗΦ (x έΙΙ dom(f) έΙπ f(x) έΙΙ dom(g))
        by comp.def [f(_) έΙΙ dom(g)] [dom(f)];
    done logically
qed

theorem composition.dom [f g : term] :
    |- έΙΑx, x έΙΙ dom(g έΙα f) έΗΦ (x έΙΙ dom(f) έΙπ f(x) έΙΙ dom(g))
proof
    follows έΙΑz, z έΙΙ dom(g έΙα f) έΗΦ έΙΔy έΙΙ (g έΙα f), z = ╧ΑέΓΒ(y) by dom.def;
    furthermore έΙΑy, y έΙΙ (g έΙα f) έΗΦ έΙΔx, (x έΙΙ dom(f) έΙπ f(x) έΙΙ dom(g)) έΙπ y = έθρx, g(f(x))έθσ by composition.def;
    indeed έΙΑx, ╧ΑέΓΒ(έθρx, g(f(x))έθσ) = x by opair_first.def;
    done logically
qed

theorem composition.is_fn [f g : term] : (f : Fn) (g : Fn)
    |- g έΙα f : Fn
proof
    -- We just want to show that g έΙα f is some functional relation
    suffices έΙΔA, έΙΔB, g έΙα f έΙΙ (A έΗΤ B) by fn.is_fn_on;
    thus έΙΑx έΙΙ {x έΙΙ dom(f) | f(x) έΙΙ dom(g)}, g(f(x)) έΙΙ ran(g) as
        -- The construction here is simple as we only pick x where f(x) is in dom(g), because
        -- g(dom(g)) being in ran(g) falls out of the definition
        arbitrary c st c έΙΙ {x έΙΙ dom(f) | f(x) έΙΙ dom(g)};
        follows g(f(c)) έΙΙ ran(g) as
            follows έΙΑx, x έΙΙ {x έΙΙ dom(f) | f(x) έΙΙ dom(g)} έΗΦ (x έΙΙ dom(f) έΙπ f(x) έΙΙ dom(g))
                by comp.def [f(_) έΙΙ dom(g)] [dom(f)];
            thus f(c) έΙΙ dom(g) logically;
            hence έθρf(c), g(f(c))έθσ έΙΙ g έΗΦ g(f(c)) = g(f(c)) by fn.apply_iff [g] [f(c)] [g(f(c))];
            hence έθρf(c), g(f(c))έθσ έΙΙ g logically;
            follows ╧ΑέΓΓ(έθρf(c), g(f(c))έθσ) = g(f(c)) by opair_second.def;
            done by ran.def given έθρf(c), g(f(c))έθσ έΙΙ g
            ;
        done logically
        ;
    -- g έΙα f is a functional mapping from dom(g έΙα f) to ran(g)
    follows g έΙα f έΙΙ ({x έΙΙ dom(f) | f(x) έΙΙ dom(g)} έΗΤ ran(g))
        by fun_map.is.rel [{x έΙΙ dom(f) | f(x) έΙΙ dom(g)}] [ran(g)] [g(f(_))];
    done logically
qed

This theorem follows cleanly from the above facts. 

theorem composition.apply [f g a : term] : (f : Fn) (g : Fn) (a έΙΙ dom(g έΙα f))
    |- (g έΙα f)(a) = g(f(a))
proof
    hence a έΙΙ dom(f) έΙπ f(a) έΙΙ dom(g) by composition.dom;
    furthermore έΙΑy, y έΙΙ (g έΙα f) έΗΦ έΙΔx, (x έΙΙ dom(f) έΙπ f(x) έΙΙ dom(g)) έΙπ y = έθρx, g(f(x))έθσ by composition.def;
    furthermore έθρa, g(f(a))έθσ έΙΙ (g έΙα f) logically;
    indeed g έΙα f : Fn by composition.is_fn;
    furthermore έθρa, g(f(a))έθσ έΙΙ (g έΙα f) έΗΦ (g έΙα f)(a) = g(f(a)) by fn.apply_iff [g έΙα f] [a] [g(f(a))];
    done logically
qed

theorem composition.is_fn_on [f g A B C : term] : (f έΙΙ (A έΗΤ B)) (g έΙΙ (B έΗΤ C))
    |- g έΙα f έΙΙ (A έΗΤ C)
proof
    hence g έΙα f : Fn by composition.is_fn, fn.is_fn_on;
    hence έΙΑx, x έΙΙ dom(g έΙα f) έΗΦ (x έΙΙ dom(f) έΙπ f(x) έΙΙ dom(g)) by composition.dom;
    follows f έΙΙ (A έΗΤ B) έΗΤ dom(f) = A έΙπ ran(f) έΛΗ B by fn_on.is_fn;
    follows g έΙΙ (B έΗΤ C) έΗΤ dom(g) = B έΙπ ran(g) έΛΗ C by fn_on.is_fn;
    indeed έΙΑx, x έΙΙ dom(g έΙα f) έΗΦ (x έΙΙ A έΙπ f(x) έΙΙ B) logically;
    hence έΙΑx, x έΙΙ A έΗΤ f(x) έΙΙ B as
        arbitrary c st c έΙΙ A;
        follows f(c) έΙΙ B as
            indeed c έΙΙ dom(f) logically;
            follows έθρc, f(c)έθσ έΙΙ f as
                indeed f : Fn by fn.is_fn_on;
                follows έθρc, f(c)έθσ έΙΙ f έΗΦ f(c) = f(c) by fn.apply_iff [f] [c] [f(c)];
                done logically
                ;
            follows f(c) έΙΙ ran(f) by opair_second.def, ran.def given έθρc, f(c)έθσ έΙΙ f;
            done by sub.def given ran(f) έΛΗ B
            ;
        ;
    hence έΙΑx, x έΙΙ dom(g έΙα f) έΗΦ x έΙΙ A logically;
    hence dom(g έΙα f) = A by zfc.extensionality;
    thus ran(g έΙα f) έΛΗ C as
        suffices έΙΑy, y έΙΙ ran(g έΙα f) έΗΤ y έΙΙ C by sub.def;
        arbitrary y;
        assume y έΙΙ ran(g έΙα f) then y έΙΙ C as
            obtain p st p έΙΙ (g έΙα f) έΙπ y = ╧ΑέΓΓ(p) by ran.def;
            obtain x st (x έΙΙ dom(f) έΙπ f(x) έΙΙ dom(g)) έΙπ p = έθρx, g(f(x))έθσ by composition.def;
            indeed g : Fn by fn.is_fn_on;
            furthermore f(x) έΙΙ dom(g) logically;
            follows έθρf(x), g(f(x))έθσ έΙΙ g έΗΦ g(f(x)) = g(f(x)) by fn.apply_iff [g] [f(x)] [g(f(x))];
            hence έθρf(x), g(f(x))έθσ έΙΙ g logically;
            follows g(f(x)) έΙΙ ran(g) by ran.def, opair_second.def given έθρf(x), g(f(x))έθσ έΙΙ g;
            done by opair_second.def, sub.def given ran(g) έΛΗ C
            ;
        done logically
        ;
    done by fn_on.is_fn
qed

theorem comp_inj.is_inj [f g A B C : term] : (f έΙΙ (A έΗμ B)) (g έΙΙ (B έΗμ C))
